generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User & Auth Tables
model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  passwordHash  String    @map("password_hash")
  role          String    @default("admin")
  createdAt     DateTime  @default(now()) @map("created_at")
  
  emailVerified DateTime? @map("email_verified")
  image         String?
  
  accounts      Account[]
  sessions      Session[]

  @@map("users")
}

model Account {
  id                 String  @id @default(cuid())
  userId             String  @map("user_id")
  type               String
  provider           String
  providerAccountId  String  @map("provider_account_id")
  refresh_token      String? @db.Text
  access_token       String? @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String? @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// Inventory Tables - Base
model Unit {
  id        Int      @id @default(autoincrement())
  name      String
  symbol    String?
  createdAt DateTime @default(now()) @map("created_at")

  conversionsFrom UnitConversion[] @relation("FromUnit")
  conversionsTo   UnitConversion[] @relation("ToUnit")
  
  // Relations to be added later: Items (base/sale unit)
  itemsBase Item[] @relation("BaseUnit")
  itemsSale Item[] @relation("SaleUnit")

  @@map("units")
}

model UnitConversion {
  id         Int      @id @default(autoincrement())
  fromUnitId Int      @map("from_unit_id")
  toUnitId   Int      @map("to_unit_id")
  factor     Decimal
  createdAt  DateTime @default(now()) @map("created_at")

  fromUnit Unit @relation("FromUnit", fields: [fromUnitId], references: [id])
  toUnit   Unit @relation("ToUnit", fields: [toUnitId], references: [id])

  @@index([fromUnitId])
  @@index([toUnitId])
  @@map("unit_conversions")
}

model Category {
  id   Int    @id @default(autoincrement())
  name String @unique

  items Item[]

  @@map("categories")
}

model Item {
  id               Int      @id @default(autoincrement())
  name             String
  categoryId       Int?     @map("category_id")
  baseUnitId       Int?     @map("base_unit_id")
  saleUnitId       Int?     @map("sale_unit_id")
  conversionFactor Decimal? @default(1) @map("conversion_factor")
  minStockLevel    Decimal? @default(0) @map("min_stock_level")
  createdAt        DateTime @default(now()) @map("created_at")

  category Category? @relation(fields: [categoryId], references: [id])
  baseUnit Unit?     @relation("BaseUnit", fields: [baseUnitId], references: [id])
  saleUnit Unit?     @relation("SaleUnit", fields: [saleUnitId], references: [id])
  
  stockLogs StockLog[]
  purchaseOrderItems PurchaseOrderItem[]

  @@index([categoryId])
  @@index([baseUnitId])
  @@index([saleUnitId])
  @@map("items")
}

model StockLog {
  id               Int      @id @default(autoincrement())
  itemId           Int      @map("item_id")
  type             String   // in/out
  quantityBaseUnit Decimal  @map("quantity_base_unit")
  description      String?
  createdAt        DateTime @default(now()) @map("created_at")

  item Item @relation(fields: [itemId], references: [id])

  @@index([itemId])
  @@map("stock_logs")
}

// Ledger Tables
model LedgerCategory {
  id   Int    @id @default(autoincrement())
  name String @unique

  ledgerEntries Ledger[]

  @@map("ledger_categories")
}

model Ledger {
  id         Int      @id @default(autoincrement())
  type       String   // debit/credit
  amount     Decimal
  categoryId Int?     @map("category_id")
  note       String?
  date       DateTime @default(now()) @db.Date
  createdAt  DateTime @default(now()) @map("created_at")

  category LedgerCategory? @relation(fields: [categoryId], references: [id])

  @@index([categoryId])
  @@map("ledger")
}

// Purchase Orders Tables
model Supplier {
  id      Int     @id @default(autoincrement())
  name    String
  phone   String?
  address String?

  purchaseOrders PurchaseOrder[]

  @@map("suppliers")
}

model PurchaseOrder {
  id          Int      @id @default(autoincrement())
  supplierId  Int?     @map("supplier_id")
  status      String   @default("draft") // draft, pending, approved, received, cancelled
  totalAmount Decimal? @default(0) @map("total_amount")
  notes       String?  @db.Text
  terms       String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")

  supplier Supplier?           @relation(fields: [supplierId], references: [id])
  items    PurchaseOrderItem[]

  @@index([supplierId])
  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id           Int     @id @default(autoincrement())
  orderId      Int     @map("order_id")
  itemId       Int     @map("item_id")
  qty          Decimal
  pricePerUnit Decimal @map("price_per_unit")

  order PurchaseOrder @relation(fields: [orderId], references: [id])
  item  Item          @relation(fields: [itemId], references: [id])

  @@index([orderId])
  @@index([itemId])
  @@map("purchase_order_items")
}

// Utilities Table
model Utility {
  id        Int      @id @default(autoincrement())
  name      String
  amount    Decimal
  dueDate   DateTime @map("due_date") @db.Date
  category  String?
  status    String?  @default("pending")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("utilities")
}

// Loan & Debt Tables
model Debt {
  id         Int      @id @default(autoincrement())
  personName String   @map("person_name")
  type       String   // loaned_out / loaned_in
  amount     Decimal
  dueDate    DateTime? @map("due_date") @db.Date
  note       String?
  createdAt  DateTime @default(now()) @map("created_at")

  payments DebtPayment[]

  @@map("debts")
}

model DebtPayment {
  id     Int      @id @default(autoincrement())
  debtId Int      @map("debt_id")
  amount Decimal
  date   DateTime @default(now()) @db.Date

  debt Debt @relation(fields: [debtId], references: [id])

  @@index([debtId])
  @@map("debt_payments")
}

// Reminders Table
model Reminder {
  id          Int      @id @default(autoincrement())
  type        String   // low_stock, bill_due, debt_due
  referenceId Int?     @map("reference_id")
  message     String?
  triggered   Boolean? @default(false)
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("reminders")
}
